int fib( int n ) 
{
    if ( n <= 2 ) 
    {
        return 1;
    }

    n -= 2;
    int prev = 1;
    int curr = 1;

    for ( int i = 0; i < n; ++i )
    {
        int tmp = curr;
        curr += prev;
        prev = tmp;
    }

    return curr;
}

int main()
{
    assert( fib( 1 ) == 1 );
    assert( fib( 2 ) == 1 );
    assert( fib( 3 ) == 2 );
    assert( fib( 4 ) == 3 );
    assert( fib( 5 ) == 5 );
    print( "finished" );   
    return 0;
}